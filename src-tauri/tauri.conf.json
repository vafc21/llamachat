{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LlamaChat",
  "version": "0.1.0",
  "identifier": "org.llamachat.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "LlamaChat",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/fitllm-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Rate which LLMs your machine can run — measured, not guessed.",
    "longDescription": "LlamaChat profiles your hardware, runs real on-device benchmarks in the background, and rates open models from 'Won't run' to 'Blazing'. Local-first, zero telemetry by default.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "Apple Development: vladimirpetrosyanjr@icloud.com (J6L2PMA8RZ)",
      "entitlements": "entitlements.plist",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  },
  "plugins": {}
}
